---
export interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
const txt = variant === 'dark' ? 'text-bone/80' : 'text-ink/70';
const bg = variant === 'dark' ? 'bg-forest-gradient border-bone/10' : 'bg-bone-soft border-ink/10';

const items = [
  { v: 'Pilotage direct', s: 'pas d\'intermédiaire commercial' },
  { v: 'Devis détaillé', s: 'ligne à ligne, sans surprise' },
  { v: 'Bureau d\'études intégré', s: 'modélisation 3D et plans' },
  { v: 'Production sur-mesure', s: 'aucun template' },
];
---

<div class={`border-y ${bg}`}>
  <div class="container-wide py-6 grid grid-cols-2 md:grid-cols-4 gap-y-4 gap-x-8">
    {items.map((it) => (
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={txt}>
          <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="leading-tight">
          <p class={`text-sm font-semibold ${txt}`}>{it.v}</p>
          <p class={`text-xs ${variant === 'dark' ? 'text-bone/40' : 'text-ink/40'}`}>{it.s}</p>
        </div>
      </div>
    ))}
  </div>
</div>
