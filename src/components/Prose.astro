---
// Wrapper pour le contenu Markdown rendu : applique une typo Apple cohérente.
---

<div class="prose-epicentre">
  <slot />
</div>

<style is:global>
  .prose-epicentre {
    max-width: 720px;
    color: rgba(11, 11, 15, 0.85);
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .prose-epicentre > * + * { margin-top: 1.5rem; }
  .prose-epicentre h2 {
    font-size: 1.875rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: #0B0B0F;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-epicentre h3 {
    font-size: 1.375rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #0B0B0F;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-epicentre p { margin-top: 1.25rem; }
  .prose-epicentre p:first-child { margin-top: 0; }
  .prose-epicentre strong { color: #0B0B0F; font-weight: 600; }
  .prose-epicentre a {
    color: #A6884F;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose-epicentre a:hover { color: #C8A86B; }
  .prose-epicentre ul,
  .prose-epicentre ol {
    margin-top: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-epicentre ul { list-style: disc; }
  .prose-epicentre ol { list-style: decimal; }
  .prose-epicentre li { margin-bottom: 0.5rem; }
  .prose-epicentre li::marker { color: rgba(11, 11, 15, 0.4); }
  .prose-epicentre blockquote {
    border-left: 2px solid #C8A86B;
    padding-left: 1.5rem;
    font-style: italic;
    color: rgba(11, 11, 15, 0.7);
    margin: 2rem 0;
  }
  .prose-epicentre hr {
    border: none;
    border-top: 1px solid rgba(11, 11, 15, 0.1);
    margin: 3.5rem 0;
  }
  .prose-epicentre em { font-style: italic; }
  .prose-epicentre code {
    background: rgba(11, 11, 15, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.95em;
  }
</style>
