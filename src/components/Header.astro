---
import Logo from './Logo.astro';
import { CONTACT_PHONE_DISPLAY, CONTACT_PHONE_HREF } from '@/config';

export interface Props {
  theme?: 'light' | 'dark';
  transparentTop?: boolean;
}
const { theme = 'dark', transparentTop = false } = Astro.props;

// Navigation propre au domaine d'Épinac. 'Le domaine' et 'Productions' ouvrent des mega-menus.
const nav = [
  { label: 'Le domaine', href: '/le-domaine/', mega: 'domaine' as const },
  { label: 'Productions', href: '/productions/', mega: 'productions' as const },
  { label: 'Contact', href: '/contact/' },
];

// Espaces visibles dans le mega 'Le domaine'
const domaineSpaces = [
  { label: 'Chapiteau cristal', desc: 'Plénière transparente, 300 pax', cover: 'https://enjoylife.b-cdn.net/Verrerie/halle.jpg' },
  { label: 'Parc 9 000 m²', desc: 'Cocktail, gala, scène extérieure', cover: 'https://enjoylife.b-cdn.net/Verrerie/fresque.jpg' },
  { label: 'Chambres sur place', desc: 'Hébergement résidentiel', cover: 'https://enjoylife.b-cdn.net/Verrerie/chambre1.png' },
  { label: 'Orangerie & atelier vin', desc: 'Dégustation, petit comité', cover: 'https://enjoylife.b-cdn.net/Verrerie/orangerie.jpg' },
];

// Formats événementiels mis en avant
const productionsFormats = [
  { label: 'Plénière sous chapiteau', desc: 'Scène, son, lumière, captation' },
  { label: 'Gala et dîner d\'entreprise', desc: 'Tables rondes en plein air' },
  { label: 'Soirée d\'entreprise', desc: 'Cocktail, animation, concert privé' },
  { label: 'Mariage premium', desc: 'Cérémonie, cocktail, dîner gala' },
  { label: 'Lancement produit plein air', desc: 'Reveal scénographié en parc' },
  { label: 'Séminaire résidentiel', desc: 'Travail + hébergement sur place' },
];

const ctaHref = '/contact/';
const ctaLabel = 'Demander une visite';
const zoneTag = 'Épinac · Bourgogne';

const phone = CONTACT_PHONE_DISPLAY;
const phoneHref = CONTACT_PHONE_HREF;

// Theme adaptable
const isLight = theme === 'light';
const logoVariant = isLight ? 'dark' : 'light';
const headerBgInitial = isLight
  ? 'bg-bone/0'
  : (transparentTop ? 'bg-transparent' : 'bg-forest-gradient');
const headerBgScrolled = isLight ? 'bg-bone/90 backdrop-blur-md' : 'bg-forest-gradient';
const borderClass = isLight ? 'border-ink/5' : 'border-bone/5';
const textBase = isLight ? 'text-ink/85' : 'text-bone/85';
const textHover = isLight ? 'hover:text-ink' : 'hover:text-bone';
const textZoneTag = isLight ? 'text-ink/55' : 'text-bone/60';
const borderZoneTag = isLight ? 'border-ink/15' : 'border-bone/20';
const phoneText = isLight ? 'text-ink hover:text-ink/70' : 'text-bone hover:text-bone/80';
const ctaClass = isLight ? 'btn-accent' : 'btn-bone';
const burgerColor = isLight ? 'text-ink' : 'text-bone';
---

<header
  id="siteHeader"
  class={`fixed top-0 left-0 right-0 z-50 transition-[background-color,backdrop-filter,padding] duration-300 ${headerBgInitial} border-b ${borderClass}`}
  data-scrolled="false"
  data-theme={theme}
  data-transparent-top={transparentTop ? 'true' : 'false'}
  data-bg-initial={headerBgInitial}
  data-bg-scrolled={headerBgScrolled}
>
  <div class="container-wide flex items-center justify-between header-row">
    <div class="flex items-center gap-4">
      <span class="header-logo inline-flex items-center transition-transform duration-300 origin-left">
        <Logo variant={logoVariant} height={56} />
      </span>
      <span class={`hidden md:flex items-center gap-3 ${textZoneTag} text-[0.7rem] uppercase tracking-[0.2em] border-l ${borderZoneTag} pl-4 ml-1`}>
        {zoneTag}
      </span>
    </div>

    <nav class={`hidden lg:flex items-center gap-7 text-sm ${textBase} font-medium`}>
      {nav.map((item) => (
        item.mega ? (
          <div class="nav-item-mega" data-mega={item.mega}>
            <a href={item.href} class={`nav-mega-link ${textHover} transition-colors flex items-center gap-1`}>
              {item.label}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="opacity-60 transition-transform">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        ) : (
          <a href={item.href} class={`${textHover} transition-colors`}>{item.label}</a>
        )
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-4">
      <a href={phoneHref} class={`${phoneText} text-sm font-semibold flex items-center gap-2 transition-colors`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>{phone}</span>
      </a>
      <a href={ctaHref} class={`${ctaClass} header-cta text-sm py-2.5 px-5`}>
        {ctaLabel}
      </a>
    </div>

    <div class="lg:hidden flex items-center gap-3">
      <button class={`${burgerColor}`} aria-label="Menu" id="mobileMenuBtn">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <line x1="3" y1="7" x2="21" y2="7" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="17" x2="21" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <!-- MEGA-MENU PANELS (desktop) -->
  <div class="mega-panel" data-mega-target="domaine" aria-hidden="true">
    <div class="container-wide py-8 md:py-10">
      <div class="flex items-end justify-between gap-6 mb-6 md:mb-8">
        <div>
          <p class="eyebrow text-ink/55">Le domaine</p>
          <h3 class="font-display text-xl md:text-2xl font-semibold text-ink mt-2 leading-tight">Quatre espaces, un parc, une liberté totale.</h3>
        </div>
        <a href="/le-domaine/" class="text-sm text-accent font-semibold flex items-center gap-1.5 hover:gap-2.5 transition-all whitespace-nowrap">
          Découvrir le domaine
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {domaineSpaces.map((s) => (
          <a href="/le-domaine/" class="group flex flex-col gap-2.5">
            <div class="relative aspect-[4/3] overflow-hidden rounded-sm bg-bone-soft">
              <img src={s.cover} alt="" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" />
            </div>
            <div>
              <p class="text-sm font-semibold text-ink leading-tight group-hover:text-accent transition-colors">{s.label}</p>
              <p class="text-xs text-ink/55 mt-1 leading-snug">{s.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="mega-panel" data-mega-target="productions" aria-hidden="true">
    <div class="container-wide py-8 md:py-10">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
        <div class="lg:col-span-8">
          <p class="eyebrow text-ink/55 mb-5">Productions au domaine</p>
          <div class="grid grid-cols-2 gap-x-6 gap-y-2">
            {productionsFormats.map((f) => (
              <a href="/productions/" class="group flex items-start gap-3 py-2 pr-2 -mx-2 px-2 rounded-sm hover:bg-bone-soft transition-colors">
                <span class="shrink-0 inline-flex items-center justify-center w-2 h-2 rounded-full bg-accent mt-2"></span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-ink leading-tight group-hover:text-accent transition-colors">{f.label}</p>
                  <p class="text-xs text-ink/55 mt-0.5 leading-snug">{f.desc}</p>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-7 pt-5 border-t border-ink/10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
            <a href="/productions/" class="text-accent font-semibold flex items-center gap-1.5 hover:gap-2.5 transition-all">
              Voir toutes les productions
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a href="https://epicentre-seminaires.fr/process/" class="text-ink/65 hover:text-accent transition-colors">Notre méthode 3D</a>
          </div>
        </div>
        <div class="lg:col-span-4">
          <a href="/le-domaine/" class="group block relative overflow-hidden rounded-sm aspect-[4/5] cinema-grade">
            <img src="https://enjoylife.b-cdn.net/Verrerie/hero.jpg" alt="" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent z-[3]"></div>
            <div class="absolute bottom-5 left-5 right-5 z-[4] text-bone">
              <p class="text-[0.6rem] uppercase tracking-[0.22em] text-bone/70 font-medium">9 000 m² privatisés</p>
              <p class="mt-2 text-base font-semibold leading-tight">Le terrain de jeu se construit avec vous.</p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-xs text-bone/85 group-hover:gap-2.5 transition-all">
                Découvrir le domaine
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- MOBILE DRAWER MENU -->
  <div id="mobileMenuBackdrop" class="lg:hidden fixed inset-0 bg-ink/60 backdrop-blur-sm opacity-0 invisible transition-opacity duration-300 z-[55]" aria-hidden="true"></div>
  <aside id="mobileMenu" class="lg:hidden fixed top-0 right-0 bottom-0 w-full max-w-sm bg-forest-gradient text-bone translate-x-full transition-transform duration-[400ms] ease-[cubic-bezier(0.22,1,0.36,1)] z-[60] flex flex-col" aria-hidden="true" aria-label="Menu mobile">
    <div class="flex items-center justify-between px-6 py-5 border-b border-bone/10">
      <Logo variant="light" height={44} />
      <button type="button" id="mobileMenuClose" aria-label="Fermer le menu" class="w-10 h-10 inline-flex items-center justify-center text-bone/70 hover:text-bone transition-colors">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-6 py-7">
      <p class="eyebrow text-bone/55 mb-5">{zoneTag}</p>
      <ul class="flex flex-col">
        {nav.map((item) => (
          <li class="border-b border-bone/10">
            <a href={item.href} class="flex items-center justify-between py-4 text-bone hover:text-bone group">
              <span class="text-lg font-medium">{item.label}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-bone/40 group-hover:text-bone group-hover:translate-x-0.5 transition-all">
                <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-8 flex flex-col gap-3 text-sm text-bone/65">
        <a href="https://epicentre-seminaires.fr" class="hover:text-bone transition-colors">Agence Plaine de l'Ain</a>
      </div>
    </nav>

    <div class="px-6 py-6 border-t border-bone/10 bg-forest-deep/30 space-y-4">
      <a href={phoneHref} class="flex items-center gap-3 text-bone hover:text-bone/85 transition-colors">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-bone/10">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span>
          <p class="text-[0.65rem] uppercase tracking-[0.18em] text-bone/55 font-medium">Direct</p>
          <p class="text-base font-semibold">{phone}</p>
        </span>
      </a>
      <a href={ctaHref} class="btn-bone w-full justify-center text-sm py-3.5">
        {ctaLabel}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </aside>
</header>

<script>
  const header = document.getElementById('siteHeader');
  const btn = document.getElementById('mobileMenuBtn');
  const menu = document.getElementById('mobileMenu');
  const backdrop = document.getElementById('mobileMenuBackdrop');
  const closeBtn = document.getElementById('mobileMenuClose');

  const openMobileMenu = () => {
    if (!menu || !backdrop) return;
    menu.classList.remove('translate-x-full');
    menu.setAttribute('aria-hidden', 'false');
    backdrop.classList.remove('opacity-0', 'invisible');
    backdrop.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  };
  const closeMobileMenu = () => {
    if (!menu || !backdrop) return;
    menu.classList.add('translate-x-full');
    menu.setAttribute('aria-hidden', 'true');
    backdrop.classList.add('opacity-0', 'invisible');
    backdrop.classList.remove('opacity-100');
    document.body.style.overflow = '';
  };

  btn?.addEventListener('click', openMobileMenu);
  closeBtn?.addEventListener('click', closeMobileMenu);
  backdrop?.addEventListener('click', closeMobileMenu);
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMobileMenu));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.classList.contains('translate-x-full')) closeMobileMenu();
  });

  const onScroll = () => {
    if (!header) return;
    const initial = header.dataset.bgInitial?.split(' ') ?? [];
    const scrolled = header.dataset.bgScrolled?.split(' ') ?? [];
    if (window.scrollY > 60) {
      initial.forEach((c) => header.classList.remove(c));
      scrolled.forEach((c) => header.classList.add(c));
      header.dataset.scrolled = 'true';
    } else {
      scrolled.forEach((c) => header.classList.remove(c));
      initial.forEach((c) => header.classList.add(c));
      header.dataset.scrolled = 'false';
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mega-menu : hover sur nav-item ouvre le panel correspondant
  const navItems = document.querySelectorAll<HTMLElement>('.nav-item-mega');
  const panels = document.querySelectorAll<HTMLElement>('.mega-panel');
  let closeTimer: number | null = null;

  const openPanel = (key: string) => {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    panels.forEach((p) => {
      const isTarget = p.dataset.megaTarget === key;
      p.classList.toggle('mega-panel--open', isTarget);
      p.setAttribute('aria-hidden', isTarget ? 'false' : 'true');
    });
    navItems.forEach((it) => {
      it.classList.toggle('nav-item-mega--active', it.dataset.mega === key);
    });
  };
  const closeAll = () => {
    panels.forEach((p) => {
      p.classList.remove('mega-panel--open');
      p.setAttribute('aria-hidden', 'true');
    });
    navItems.forEach((it) => it.classList.remove('nav-item-mega--active'));
  };
  const scheduleClose = () => {
    if (closeTimer) clearTimeout(closeTimer);
    closeTimer = window.setTimeout(closeAll, 150);
  };

  navItems.forEach((it) => {
    const key = it.dataset.mega;
    if (!key) return;
    it.addEventListener('mouseenter', () => openPanel(key));
    it.addEventListener('mouseleave', scheduleClose);
    it.addEventListener('focusin', () => openPanel(key));
  });
  panels.forEach((p) => {
    p.addEventListener('mouseenter', () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    });
    p.addEventListener('mouseleave', scheduleClose);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });
</script>

<style>
  .header-row {
    padding-top: 1rem;
    padding-bottom: 1rem;
    transition: padding 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (min-width: 768px) {
    .header-row { padding-top: 1.25rem; padding-bottom: 1.25rem; }
  }
  #siteHeader[data-scrolled="true"] .header-row {
    padding-top: 0.35rem;
    padding-bottom: 0.35rem;
  }
  #siteHeader[data-scrolled="true"] .header-logo {
    transform: scale(0.7);
  }
  #siteHeader .header-cta {
    transition: padding 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #siteHeader[data-scrolled="true"] .header-cta {
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .header-row, .header-logo, #siteHeader .header-cta { transition: none; }
  }

  /* ============== MEGA-MENU ============== */
  .nav-item-mega {
    position: static;
    cursor: pointer;
  }
  .nav-item-mega .nav-mega-link svg {
    transition: transform 0.2s ease;
  }
  .nav-item-mega--active .nav-mega-link svg {
    transform: rotate(180deg);
  }
  .mega-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #F5F1EA;
    border-top: 1px solid rgba(11, 11, 15, 0.08);
    box-shadow: 0 16px 40px -20px rgba(11, 11, 15, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.25s cubic-bezier(0.22, 1, 0.36, 1), transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.25s;
    pointer-events: none;
    z-index: 49;
    max-height: calc(100vh - 80px);
    overflow-y: auto;
  }
  .mega-panel--open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .mega-panel { transition: none; }
  }
</style>
