    color: #F5F1EA;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    z-index: 10;
    transition: opacity 0.2s;
  }
  .legal-dialog__close:hover { opacity: 0.85; }

  @media (min-width: 768px) {
    .legal-dialog__close {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
    }
  }

  .legal-dialog__content {
    max-width: 100%;
  }
  .legal-section {
    margin-bottom: 2.5rem;
  }
  .legal-section h3 {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 0.75rem;
  }
  .legal-section p,
  .legal-section li {
    color: rgba(11, 11, 15, 0.75);
    line-height: 1.65;
    font-size: 0.95rem;
  }
  .legal-section p + p { margin-top: 0.75rem; }
  .legal-section ul {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .legal-section ul li { margin-bottom: 0.4rem; }
  .legal-section a {
    color: #00491b;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .legal-section a:hover { color: #003707; }
  .legal-section strong { font-weight: 600; color: #0B0B0F; }

  .legal-update {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(11, 11, 15, 0.1);
    font-size: 0.8rem;
    color: rgba(11, 11, 15, 0.4);
    font-style: italic;
  }

  .link-inline {
    background: none;
    border: none;
    padding: 0;
    color: #00491b;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    font: inherit;
  }
  .link-inline:hover { color: #003707; }
</style>

<script>
  // Open dialog
  document.querySelectorAll<HTMLButtonElement>('[data-open-dialog]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-open-dialog');
      if (!id) return;
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      // Close any other open dialogs
      document.querySelectorAll<HTMLDialogElement>('dialog[open]').forEach((d) => d.close());
      dialog?.showModal();
    });
  });

  // Close button
  document.querySelectorAll<HTMLButtonElement>('[data-close-dialog]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-close-dialog');
      if (!id) return;
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      dialog?.close();
    });
  });

  // Click outside to close
  document.querySelectorAll<HTMLDialogElement>('dialog.legal-dialog').forEach((dialog) => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
