---
import Base from '@/layouts/Base.astro';

const title = "Page introuvable | Domaine d'Épinac";
const description = "La page que vous cherchez n'existe pas ou plus. Reprenez par les sections principales du Domaine d'Épinac.";

const heroBg = 'https://images.unsplash.com/photo-1582719508461-905c673771fd?w=2400&q=85&auto=format&fit=crop';
---

<Base title={title} description={description} noindex={true}>
  <section class="relative min-h-screen bg-ink text-bone overflow-hidden flex items-center pt-32 md:pt-36 pb-20">
    <!-- Background image floutée -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <img
        src={heroBg}
        alt=""
        loading="eager"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover opacity-25"
        style="filter: blur(4px) saturate(0.85)"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/70 to-forest-deep/80"></div>
    </div>

    <!-- Halo accent emerald -->
    <div class="absolute top-1/4 right-[-10%] w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle,rgba(0,73,27,0.45)_0%,transparent_60%)] pointer-events-none"></div>

    <div class="container-wide relative z-10 text-center max-w-3xl mx-auto">
      <!-- Code 404 visuel -->
      <p class="font-display text-[8rem] md:text-[12rem] leading-none tracking-[-0.04em] text-bone/15 select-none mb-2">404</p>

      <p class="text-[0.7rem] uppercase tracking-[0.22em] text-bone/55 font-medium">Page introuvable</p>
      <h1 class="font-display font-semibold mt-5 leading-[0.98] tracking-[-0.04em] !text-bone" style="font-size: clamp(2.25rem, 5vw, 4rem);">
        Vous avez quitté le domaine.
      </h1>
      <p class="mt-7 text-lg md:text-xl text-bone/75 leading-relaxed max-w-xl mx-auto">
        La page que vous cherchez n'existe pas, plus, ou jamais. Reprenez par une des entrées principales.
      </p>

      <!-- Recovery cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mt-12">
        <a href="/" class="recovery-card">
          <span class="recovery-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round" />
              <polyline points="9 22 9 12 15 12 15 22" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="recovery-card__label">Accueil</span>
        </a>
        <a href="/le-domaine/" class="recovery-card">
          <span class="recovery-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 21V8l9-5 9 5v13" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M9 21V12h6v9" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="recovery-card__label">Le Domaine</span>
        </a>
        <a href="/productions/" class="recovery-card">
          <span class="recovery-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round" />
              <line x1="3" y1="21" x2="21" y2="21" stroke-linecap="round" />
            </svg>
          </span>
          <span class="recovery-card__label">Productions</span>
        </a>
        <a href="/contact/" class="recovery-card">
          <span class="recovery-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="recovery-card__label">Contact</span>
        </a>
      </div>

      <!-- Lien complémentaire vers le site principal -->
      <p class="mt-12 text-sm text-bone/55">
        Vous cherchez l'agence événementielle ?
        <a href="https://epicentre-seminaires.fr" class="text-bone hover:text-bone/80 underline underline-offset-4 transition-colors ml-1">epicentre-seminaires.fr</a>
      </p>
    </div>
  </section>

  <style>
    .recovery-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 1.4rem 1rem;
      background: rgba(245, 241, 234, 0.04);
      border: 1px solid rgba(245, 241, 234, 0.15);
      border-radius: 6px;
      color: rgba(245, 241, 234, 0.85);
      transition: all 0.25s ease;
      backdrop-filter: blur(6px);
    }
    .recovery-card:hover {
      background: rgba(245, 241, 234, 0.10);
      border-color: rgba(245, 241, 234, 0.45);
      color: #F5F1EA;
      transform: translateY(-2px);
    }
    .recovery-card__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      background: rgba(245, 241, 234, 0.08);
    }
    .recovery-card__label {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: -0.005em;
      line-height: 1.2;
      text-align: center;
    }
  </style>
</Base>
