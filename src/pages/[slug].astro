---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Prose from '@/components/Prose.astro';
import PageFaq from '@/components/PageFaq.astro';
import NearbyLinks from '@/components/NearbyLinks.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

export async function getStaticPaths() {
  const lieux = await getCollection('lieux', (l) => l.data.zone === 'epinac');
  return lieux.map((lieu) => ({
    params: { slug: lieu.id },
    props: { lieu },
  }));
}

const { lieu } = Astro.props;
const { Content } = await render(lieu);

const siteUrl = 'https://epinac.epicentre-seminaires.fr';
const pageUrl = `${siteUrl}/${lieu.id}/`;

const breadcrumb = [
  { name: 'Accueil', url: '/' },
  { name: lieu.data.ville },
];

const faqJsonLd = lieu.data.faq && lieu.data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: lieu.data.faq.map((it) => ({
        '@type': 'Question',
        name: it.q,
        acceptedAnswer: { '@type': 'Answer', text: it.a },
      })),
    }
  : null;

const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EventVenue',
  '@id': `${pageUrl}#venue`,
  name: `Domaine d'Épinac (accès depuis ${lieu.data.ville})`,
  description: lieu.data.description,
  url: pageUrl,
  image: lieu.data.cover,
  areaServed: { '@type': 'City', name: lieu.data.ville },
  ...(lieu.data.geo && {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: lieu.data.geo.lat,
      longitude: lieu.data.geo.lng,
    },
  }),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Épinac',
    postalCode: '71360',
    addressRegion: 'Bourgogne-Franche-Comté',
    addressCountry: 'FR',
  },
};
---

<Base title={`${lieu.data.title} | Domaine d'Épinac`} description={lieu.data.description} image={lieu.data.cover}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

  <article>
    <section class="relative h-[55vh] min-h-[380px] overflow-hidden bg-ink cinema-grade">
      <img src={lieu.data.cover} alt={lieu.data.title} class="absolute inset-0 w-full h-full object-cover opacity-55" />
      <div class="absolute inset-0 bg-gradient-to-b from-forest-deep/30 to-forest-deep"></div>
      <div class="relative z-10 h-full container-wide flex flex-col justify-end pb-16 text-bone">
        <Breadcrumb items={breadcrumb} variant="dark" />
        <h1 class="text-3xl md:text-5xl lg:text-6xl max-w-4xl leading-tight mt-6">
          {lieu.data.title}
        </h1>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-bone">
      <div class="container-wide">
        <Prose>
          <Content />
        </Prose>
      </div>
    </section>

    {lieu.data.faq && lieu.data.faq.length > 0 && (
      <PageFaq items={lieu.data.faq} heading={`Vos questions sur un séminaire à ${lieu.data.ville} ou Épinac.`} />
    )}

    <NearbyLinks
      currentSlug={lieu.id}
      villes={lieu.data.nearbyVilles}
    />

    <section class="bg-bone py-20 md:py-28 border-t border-ink/10">
      <div class="container-wide">
        <div class="bg-bone-soft rounded-3xl p-8 md:p-14 lg:p-20 max-w-5xl mx-auto text-center">
          <p class="eyebrow text-ink/55">Visite du domaine</p>
          <h2 class="font-display text-3xl md:text-5xl mt-5 leading-tight text-ink">
            Visitons le domaine <span class="text-gradient">ensemble.</span>
          </h2>
          <p class="mt-6 text-base md:text-lg text-ink/65 max-w-xl mx-auto leading-relaxed">
            Une demi-journée sur place suffit pour imaginer votre séminaire.
          </p>
          <a href="/contact/" class="btn-accent mt-10 inline-flex">
            Réserver une visite
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </article>
</Base>
