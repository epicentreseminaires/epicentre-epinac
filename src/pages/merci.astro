---
import Base from '@/layouts/Base.astro';

const title = "Merci pour votre demande | Epicentre Séminaires";
const description = "Votre demande a bien été reçue. Nous reviendrons vers vous pour échanger sur votre projet.";
---

<Base title={title} description={description} noindex={true}>
  <section class="bg-bone min-h-screen flex items-center pt-28 md:pt-36 pb-20">
    <div class="container-wide">
      <div class="bg-bone-soft rounded-3xl p-8 md:p-14 lg:p-20 max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full bg-forest-gradient text-bone mb-10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <p class="eyebrow text-ink/55">Demande envoyée</p>
        <h1 class="font-display text-3xl md:text-5xl font-semibold mt-5 leading-tight text-ink">
          Merci.<br /><span class="text-gradient">Votre demande est bien arrivée.</span>
        </h1>
        <p class="mt-8 text-base md:text-lg text-ink/65 max-w-xl mx-auto leading-relaxed">
          Nous étudions votre projet et nous reviendrons vers vous pour en échanger.
        </p>

        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="/" class="btn-accent">Retour à l'accueil</a>
          <a href="/le-domaine/" class="btn-outline">Découvrir le domaine</a>
        </div>
      </div>
    </div>
  </section>
</Base>
